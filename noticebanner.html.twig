{% if particle.enabled %}
{% set banner_id = 'notice-banner-' ~ particle.id|default('default') %}
<div
    id="{{ banner_id }}"
    class="notice-banner"
    data-banner-id="{{ banner_id }}"
    role="alert"
    aria-live="polite"
    style="
        background-color: {{ particle.background|default('#ffcc00') }};
        color: {{ particle.text_color|default('#333333') }};
        padding: 12px 48px 12px 16px;
        position: relative;
        width: 100%;
        box-sizing: border-box;
    "
>
    <span class="notice-banner-content">{{ particle.content | raw }}</span>
    <button
        class="notice-banner-close"
        data-action="dismiss"
        aria-label="{{ particle.close_label|default('Close notice') }}"
        style="
            position: absolute;
            top: 50%;
            right: 12px;
            transform: translateY(-50%);
            background: none;
            border: none;
            font-size: 20px;
            line-height: 1;
            cursor: pointer;
            color: {{ particle.text_color|default('#333333') }};
            padding: 0 4px;
        "
    >&times;</button>
</div>

<style>
    .notice-banner {
        display: none;
    }
    .notice-banner.is-visible {
        display: block;
    }
</style>

<script>
(function () {
    /**
     * Notice Banner Handler
     * Manages banner visibility and dismissal state via sessionStorage
     */
    function initializeNoticeBanner() {
        var banner = document.getElementById('{{ banner_id }}');
        if (!banner) return;

        var bannerId = banner.dataset.bannerId;
        var storageKey = 'noticeBannerDismissed_' + bannerId;
        var closeButton = banner.querySelector('.notice-banner-close');

        // Show banner if not previously dismissed in this session
        if (!sessionStorage.getItem(storageKey)) {
            banner.classList.add('is-visible');
        }

        // Handle close button click
        if (closeButton) {
            closeButton.addEventListener('click', function (e) {
                e.preventDefault();
                banner.classList.remove('is-visible');
                sessionStorage.setItem(storageKey, '1');
            });
        }
    }

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeNoticeBanner);
    } else {
        initializeNoticeBanner();
    }
}());
</script>
{% endif %}
