{% if particle.enabled %}
{% set banner_id = 'notice-banner-' ~ particle.id|default('default') %}
<div
    id="{{ banner_id }}"
    class="notice-banner"
    role="alert"
    aria-live="polite"
    style="
        background-color: {{ particle.background|default('#ffcc00') }};
        color: {{ particle.text_color|default('#333333') }};
        display: none;
        padding: 12px 48px 12px 16px;
        position: relative;
        width: 100%;
        box-sizing: border-box;
    "
>
    <span class="notice-banner-content">{{ particle.content | raw }}</span>
    <button
        class="notice-banner-close"
        aria-label="{{ particle.close_label|default('Close notice') }}"
        style="
            position: absolute;
            top: 50%;
            right: 12px;
            transform: translateY(-50%);
            background: none;
            border: none;
            font-size: 20px;
            line-height: 1;
            cursor: pointer;
            color: {{ particle.text_color|default('#333333') }};
            padding: 0 4px;
        "
    >&times;</button>
</div>

<script>
(function () {
    var storageKey = 'noticeBannerDismissed_{{ banner_id }}';
    var banner = document.getElementById('{{ banner_id }}');

    if (!banner) return;

    // Only show if the user hasn't already dismissed it
    if (!sessionStorage.getItem(storageKey)) {
        banner.style.display = 'block';
    }

    banner.querySelector('.notice-banner-close').addEventListener('click', function () {
        banner.style.display = 'none';
        sessionStorage.setItem(storageKey, '1');
    });
}());
</script>
{% endif %}
